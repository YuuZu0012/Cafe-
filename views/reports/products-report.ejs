<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <script src="/js/jquery-3.4.1.slim.min.js"></script>
    <script src="/js/popper.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
    <link rel="stylesheet" href="/css/all.css">

    <style>
        body {
            background: linear-gradient(180deg, #fff8fd 0%, #fffdfd 45%, #f9fbff 100%);
            font-family: Arial, sans-serif;
            color: #6c5b70;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at top left, rgba(255, 214, 233, 0.30), transparent 24%),
                radial-gradient(circle at top right, rgba(210, 236, 255, 0.28), transparent 22%),
                radial-gradient(circle at bottom left, rgba(236, 220, 255, 0.20), transparent 22%);
            z-index: -2;
        }

        .floating-icecream {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: -1;
            overflow: hidden;
        }

        .float-item {
            position: absolute;
            font-size: 24px;
            opacity: 0.18;
            animation: iceFloat 7s ease-in-out infinite;
        }

        .float-item.i1 { top: 90px; left: 7%; animation-delay: 0s; }
        .float-item.i2 { top: 150px; right: 12%; animation-delay: 1.5s; }
        .float-item.i3 { bottom: 120px; left: 10%; animation-delay: 3s; }
        .float-item.i4 { bottom: 90px; right: 8%; animation-delay: 4.5s; }

        @keyframes iceFloat {
            0%, 100% { transform: translateY(0) rotate(0deg) scale(1); }
            50% { transform: translateY(-10px) rotate(5deg) scale(1.05); }
        }

        .wrap {
            max-width: 1100px;
            margin: 34px auto;
            padding: 0 16px 40px;
        }

        .hero-box {
            background: linear-gradient(135deg, rgba(255, 240, 247, 0.96), rgba(237, 247, 255, 0.96), rgba(246, 240, 255, 0.96));
            border-radius: 34px;
            padding: 30px 24px;
            text-align: center;
            box-shadow: 0 18px 34px rgba(213, 179, 210, 0.16);
            margin-bottom: 24px;
            border: 1px solid rgba(243, 223, 240, 0.85);
            position: relative;
            overflow: hidden;
            animation: fadeUp 0.8s ease;
        }

        .hero-box::after {
            content: "sweet ice cream";
            position: absolute;
            top: 16px;
            right: 18px;
            background: rgba(255, 255, 255, 0.72);
            color: #b07ea7;
            padding: 8px 14px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: bold;
            letter-spacing: 0.4px;
            animation: pulseTag 2.4s ease-in-out infinite;
        }

        @keyframes pulseTag {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.04); }
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-title {
            margin: 0;
            font-size: 2rem;
            font-weight: bold;
            color: #8a5c84;
        }

        .hero-subtitle {
            margin: 10px 0 0;
            color: #a07a9e;
        }

        .card-box {
            background: rgba(255, 255, 255, 0.96);
            border-radius: 28px;
            padding: 24px;
            box-shadow: 0 14px 30px rgba(213, 179, 210, 0.14);
            margin-bottom: 22px;
            border: 1px solid rgba(245, 226, 243, 0.85);
            animation: fadeUp 0.9s ease;
        }

        .section-title {
            color: #8a5c84;
            font-weight: bold;
            margin-bottom: 18px;
        }

        .table {
            overflow: hidden;
            border-radius: 22px;
            background: white;
            margin-bottom: 0;
        }

        .table thead th {
            background: linear-gradient(135deg, #ffd9ef, #dff2ff, #f0e2ff);
            color: #815d80;
            border: none;
            text-align: center;
            white-space: nowrap;
        }

        .table td {
            vertical-align: middle;
            text-align: center;
            color: #6d5d70;
            border-top: 1px solid #f6e4f2;
        }

        .table tbody tr:nth-child(even) td {
            background: #fffafd;
        }

        .table tbody tr:hover td {
            background: #fff3fb;
            transition: 0.2s ease;
        }

        .item-name {
            font-weight: bold;
            color: #7f5f81;
        }

        .qty-badge {
            display: inline-block;
            background: linear-gradient(135deg, #ffe4f2, #ffeedd);
            color: #b2708e;
            border-radius: 999px;
            padding: 6px 12px;
            font-weight: bold;
            min-width: 54px;
        }

        .revenue-pill {
            display: inline-block;
            background: linear-gradient(135deg, #dff3ff, #f0e7ff);
            color: #6b78aa;
            border-radius: 999px;
            padding: 6px 12px;
            font-weight: bold;
        }

        .chart-box {
            background: linear-gradient(135deg, #fffdfd, #fff8fd);
            border-radius: 24px;
            padding: 18px;
            border: 1px dashed #efdaef;
        }

        .chart-title {
            color: #8a5c84;
            font-weight: bold;
            margin-bottom: 14px;
        }

        .note-box {
            margin-top: 18px;
            padding: 14px 16px;
            background: linear-gradient(135deg, #fff3fb, #f7f1ff);
            border-left: 5px solid #e6b9dd;
            border-radius: 18px;
            color: #9a75a0;
            font-size: 14px;
        }

        @media (max-width: 768px) {
            .hero-title {
                font-size: 1.6rem;
            }
        }
    </style>
</head>
<body>
    <div class="floating-icecream">
        <div class="float-item i1">🍦</div>
        <div class="float-item i2">🍨</div>
        <div class="float-item i3">🧁</div>
        <div class="float-item i4">🍧</div>
    </div>

    <%- include('../navbar.ejs') %>

    <div class="wrap">
        <div class="hero-box">
            <h1 class="hero-title">🍨 รายงานสินค้าที่ขาย</h1>
            <p class="hero-subtitle">สรุปสินค้า จำนวนที่ขาย และรายได้ ในโทนไอติมหวานละมุนสุด ๆ</p>
        </div>

        <div class="card-box">
            <h2 class="section-title">ตารางสรุปยอดขายสินค้า</h2>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>สินค้า</th>
                        <th>จำนวนที่ขาย</th>
                        <th>รายได้</th>
                    </tr>
                </thead>
                <tbody>
                    <% productsReport.forEach(item => { %>
                        <tr>
                            <td class="item-name"><%= item.name %></td>
                            <td><span class="qty-badge"><%= item.qty %></span></td>
                            <td><span class="revenue-pill">฿ <%= Number(item.revenue).toFixed(2) %></span></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="card-box">
            <div class="chart-box">
                <h4 class="chart-title">กราฟจำนวนสินค้าที่ขาย</h4>
                <canvas id="productChart"></canvas>
            </div>

            <div class="note-box">
                ✨ หน้านี้ช่วยให้เห็นว่าสินค้าเมนูไหนขายได้มากที่สุด และสร้างรายได้ได้มากน้อยแค่ไหนแบบดูง่ายและน่ารักขึ้น
            </div>
        </div>
    </div>

    <script id="product-labels" type="application/json"><%- JSON.stringify(labels || []) %></script>
    <script id="product-qty-values" type="application/json"><%- JSON.stringify(qtyValues || []) %></script>

    <script>
        const productLabels = JSON.parse(document.getElementById('product-labels').textContent);
        const productQtyValues = JSON.parse(document.getElementById('product-qty-values').textContent);

        const productCtx = document.getElementById('productChart');

        new Chart(productCtx, {
            type: 'bar',
            data: {
                labels: productLabels,
                datasets: [{
                    label: 'จำนวนที่ขาย',
                    data: productQtyValues,
                    backgroundColor: [
                        '#ffd1ea',
                        '#cfeeff',
                        '#ead8ff',
                        '#ffe6cf',
                        '#dff8f1',
                        '#ffdede',
                        '#e3dbff',
                        '#ffe0f0'
                    ],
                    borderRadius: 14,
                    borderSkipped: false
                }]
            },
            options: {
                animation: {
                    duration: 1600
                },
                plugins: {
                    legend: {
                        labels: {
                            color: '#7c5d7e',
                            font: {
                                size: 14
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: {
                            color: '#8b6f8c'
                        },
                        grid: {
                            display: false
                        }
                    },
                    y: {
                        ticks: {
                            color: '#8b6f8c'
                        },
                        grid: {
                            color: 'rgba(230, 210, 235, 0.5)'
                        }
                    }
                }
            }
        });
    </script>
</body>
</html>