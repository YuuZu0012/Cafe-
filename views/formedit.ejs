<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>

    <link rel="stylesheet" href="/css/bootstrap.min.css"
        integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh"
        crossorigin="anonymous" />
    <script src="/js/jquery-3.4.1.slim.min.js"
        integrity="sha384-J6qa4849blE2+poT4WnyKhv5vZF5SrPo0iEjwBvKU7imGFAV0wwj1yYfoRSJoZ+n"
        crossorigin="anonymous"></script>
    <script src="/js/popper.min.js"
        integrity="sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo"
        crossorigin="anonymous"></script>
    <script src="/js/bootstrap.min.js"
        integrity="sha384-wfSDF2E50Y2D1uUdj0O3uMBJnjuUD4Ih7YwaYd1iqfktj0Uod8GCExl3Og8ifwB6"
        crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/css/all.css"
        integrity="sha384-50oBUHEmvpQ+1lW4y57PTFmhCaXp0ML5d60M1M7uH2+nqUivzIebhndOJK28anvf"
        crossorigin="anonymous" />

    <style>
        body {
            background: linear-gradient(180deg, #fff7fb 0%, #fffdf9 100%);
            font-family: Arial, sans-serif;
            color: #6f5863;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at top left, rgba(255, 214, 230, 0.35), transparent 28%),
                radial-gradient(circle at bottom right, rgba(220, 240, 255, 0.28), transparent 30%);
            z-index: -1;
        }

        .edit-wrap {
            padding: 35px 0 50px;
        }

        .edit-card {
            background: rgba(255, 255, 255, 0.96);
            border: none;
            border-radius: 30px;
            box-shadow: 0 18px 35px rgba(210, 170, 188, 0.18);
            overflow: hidden;
        }

        .edit-header {
            background: linear-gradient(135deg, #ffdce8, #e7f4ff, #fff0df);
            padding: 24px 30px;
            text-align: center;
        }

        .edit-header h2 {
            margin: 0;
            color: #7f5b71;
            font-weight: bold;
        }

        .edit-header p {
            margin: 8px 0 0;
            color: #9a7283;
        }

        .edit-body {
            padding: 30px 28px;
        }

        .form-group label {
            font-weight: bold;
            color: #8a6275;
            margin-bottom: 8px;
        }

        .form-control {
            border-radius: 18px;
            border: 1px solid #f5cfdb;
            background: #fffafd;
            padding: 12px 16px;
            box-shadow: inset 0 2px 6px rgba(255, 222, 232, 0.14);
            transition: all 0.25s ease;
        }

        .form-control:focus {
            border-color: #ffbfd0;
            box-shadow: 0 0 0 4px rgba(255, 182, 193, 0.18);
        }

        textarea.form-control {
            resize: none;
        }

        .upload-box {
            background: linear-gradient(135deg, #fff1f7, #eef8ff);
            border: 1px dashed #f3bfd0;
            border-radius: 20px;
            padding: 14px;
        }

        .file-row {
            display: flex;
            gap: 0;
            align-items: center;
        }

        .cute-input {
            border-radius: 999px 0 0 999px !important;
            border: 1px solid #f5cfdb;
            background: #fffafd;
            padding: 12px 16px;
        }

        .cute-file-btn {
            background: linear-gradient(135deg, #ffb6c9, #b8e3ff);
            color: #fff;
            font-weight: bold;
            padding: 12px 20px;
            border-radius: 0 999px 999px 0;
            cursor: pointer;
            border: none;
            min-width: 120px;
            text-align: center;
            box-shadow: 0 8px 16px rgba(255, 182, 193, 0.18);
            transition: all 0.25s ease;
            margin-bottom: 0;
        }

        .cute-file-btn:hover {
            transform: translateY(-1px);
            opacity: 0.95;
        }

        .preview-box {
            margin-top: 14px;
            text-align: center;
            background: #fffafd;
            border: 1px solid #f8dbe5;
            border-radius: 22px;
            padding: 16px;
        }

        .preview-label {
            color: #9b7081;
            font-size: 14px;
            margin-bottom: 10px;
            font-weight: bold;
        }

        .product-preview {
            width: 180px;
            height: 180px;
            object-fit: cover;
            border-radius: 24px;
            box-shadow: 0 10px 22px rgba(200, 158, 176, 0.18);
            background: linear-gradient(135deg, #ffe5ef, #fff1e6);
            padding: 6px;
        }

        .submit-btn {
            background: linear-gradient(135deg, #ffb6c9, #ffc9a9);
            border: none;
            color: white;
            font-weight: bold;
            border-radius: 999px;
            padding: 12px 26px;
            box-shadow: 0 10px 20px rgba(255, 182, 193, 0.22);
            transition: all 0.25s ease;
        }

        .submit-btn:hover {
            background: linear-gradient(135deg, #ffa8c0, #ffba91);
            transform: translateY(-2px);
            color: white;
        }

        .back-btn {
            display: inline-block;
            margin-left: 10px;
            background: linear-gradient(135deg, #b8e3ff, #d6f3ff);
            color: #5f7898;
            font-weight: bold;
            text-decoration: none;
            border-radius: 999px;
            padding: 12px 22px;
            box-shadow: 0 10px 20px rgba(184, 227, 255, 0.22);
            transition: all 0.25s ease;
        }

        .back-btn:hover {
            text-decoration: none;
            color: #476885;
            transform: translateY(-2px);
        }

        .cute-note {
            margin-top: 14px;
            padding: 12px 16px;
            border-radius: 18px;
            background: #fff6fa;
            color: #a06e82;
            border-left: 4px solid #ffbfd0;
            font-size: 14px;
        }

        @media (max-width: 768px) {
            .edit-body {
                padding: 24px 18px;
            }

            .file-row {
                flex-direction: column;
                gap: 10px;
            }

            .cute-input,
            .cute-file-btn {
                border-radius: 999px !important;
                width: 100%;
            }

            .back-btn {
                display: inline-block;
                margin-left: 0;
                margin-top: 10px;
            }
        }
    </style>
</head>

<body>
    <%- include('navbar.ejs') %>

    <div class="container edit-wrap">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="edit-card">
                    <div class="edit-header">
                        <h2>🧁 แก้ไขสินค้า</h2>
                        <p>ปรับรายละเอียดเมนูให้น่ารักและน่ากินยิ่งขึ้น</p>
                    </div>

                    <div class="edit-body">
                        <form class="form-horizontal" method="POST" action="/update" enctype="multipart/form-data">
                            <input type="hidden" value="<%= product._id %>" name="id">

                            <div class="form-group">
                                <label>ชื่อสินค้า</label>
                                <input type="text" class="form-control" name="name" value="<%= product.name %>">
                            </div>

                            <div class="form-group">
                                <label>ราคา</label>
                                <input type="text" class="form-control" name="price" value="<%= product.price %>">
                            </div>

                            <div class="form-group">
                                <label>ภาพสินค้า</label>

                                <div class="upload-box">
                                    <div class="file-row">
                                        <input type="text" id="file-name" class="form-control cute-input"
                                               placeholder="ยังไม่ได้เลือกไฟล์ใหม่" readonly>
                                        <label for="imageUpload" class="cute-file-btn">เลือกไฟล์</label>
                                    </div>

                                    <input type="file" id="imageUpload" class="d-none" name="image" accept="image/*">

                                    <div class="mt-3">
                                        <label>หรือวาง URL รูปภาพ</label>
                                        <input type="text" class="form-control" name="imageUrl" id="imageUrl"
                                               value="<%= product.image && product.image.startsWith('http') ? product.image : '' %>"
                                               placeholder="https://example.com/image.jpg">
                                    </div>

                                    <div class="preview-box">
                                        <div class="preview-label">
                                            Current File:
                                            <%= product.image %>
                                        </div>
                                        <img id="previewImage"
                                             class="product-preview"
                                             src="<%= product.image && product.image.startsWith('http') ? product.image : '/images/products/' + product.image %>"
                                             alt="<%= product.name %>">
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label>รายละเอียด</label>
                                <textarea class="form-control" cols="30" rows="4" name="description"><%= product.description %></textarea>
                            </div>

                            <div class="cute-note">
                                ✨ เลือกได้ทั้งอัปโหลดไฟล์ใหม่ หรือวาง URL รูปภาพ ถ้าไม่เปลี่ยน ระบบจะใช้รูปเดิมต่อ
                            </div>

                            <div class="form-group mt-4">
                                <button type="submit" class="submit-btn">💾 บันทึก</button>
                                <a class="back-btn" href="/manage">ย้อนกลับ</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const imageUpload = document.getElementById("imageUpload");
        const fileName = document.getElementById("file-name");
        const imageUrl = document.getElementById("imageUrl");
        const previewImage = document.getElementById("previewImage");

        if (imageUpload) {
            imageUpload.addEventListener("change", function () {
                if (this.files.length > 0) {
                    fileName.value = this.files[0].name;
                    const file = this.files[0];
                    const reader = new FileReader();

                    reader.onload = function (e) {
                        previewImage.src = e.target.result;
                    };

                    reader.readAsDataURL(file);
                } else {
                    fileName.value = "";
                }
            });
        }

        if (imageUrl) {
            imageUrl.addEventListener("input", function () {
                const url = this.value.trim();
                if (url.startsWith("http")) {
                    previewImage.src = url;
                }
            });
        }
    </script>
</body>
</html>