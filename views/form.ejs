<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="/css/bootstrap.min.css">
<script src="/js/jquery-3.4.1.slim.min.js"></script>
<script src="/js/popper.min.js"></script>
<script src="/js/bootstrap.min.js"></script>
<link rel="stylesheet" href="/css/all.css">

    <style>
      body {
        background: linear-gradient(180deg, #fff7fb 0%, #fffdf9 100%);
        font-family: Arial, sans-serif;
        color: #6f5863;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background:
          radial-gradient(
            circle at top left,
            rgba(255, 214, 230, 0.35),
            transparent 28%
          ),
          radial-gradient(
            circle at bottom right,
            rgba(220, 240, 255, 0.28),
            transparent 30%
          );
        z-index: -1;
      }

      .form-page {
        padding: 35px 0 50px;
      }

      .form-card {
        background: rgba(255, 255, 255, 0.95);
        border: none;
        border-radius: 30px;
        box-shadow: 0 18px 35px rgba(210, 170, 188, 0.18);
        overflow: hidden;
      }

      .form-header {
        background: linear-gradient(135deg, #ffdce8, #e7f4ff, #fff0df);
        padding: 24px 30px;
        text-align: center;
      }

      .form-header h2 {
        margin: 0;
        color: #7f5b71;
        font-weight: bold;
      }

      .form-header p {
        margin: 8px 0 0;
        color: #9a7283;
      }

      .form-body {
        padding: 30px 28px;
      }

      .form-group label {
        font-weight: bold;
        color: #8a6275;
        margin-bottom: 8px;
      }

      .form-control {
        border-radius: 18px;
        border: 1px solid #f5cfdb;
        background: #fffafd;
        padding: 12px 16px;
        box-shadow: inset 0 2px 6px rgba(255, 222, 232, 0.14);
        transition: all 0.25s ease;
      }

      .form-control:focus {
        border-color: #ffbfd0;
        box-shadow: 0 0 0 4px rgba(255, 182, 193, 0.18);
      }

      textarea.form-control {
        resize: none;
      }

      .custom-file-box {
        background: linear-gradient(135deg, #fff1f7, #eef8ff);
        border: 1px dashed #f3bfd0;
        border-radius: 20px;
        padding: 14px;
      }

      .submit-btn {
        background: linear-gradient(135deg, #ffb6c9, #ffc9a9);
        border: none;
        color: white;
        font-weight: bold;
        border-radius: 999px;
        padding: 12px 26px;
        box-shadow: 0 10px 20px rgba(255, 182, 193, 0.22);
        transition: all 0.25s ease;
      }

      .submit-btn:hover {
        background: linear-gradient(135deg, #ffa8c0, #ffba91);
        transform: translateY(-2px);
        color: white;
      }

      .back-btn {
        display: inline-block;
        margin-left: 10px;
        background: linear-gradient(135deg, #b8e3ff, #d6f3ff);
        color: #5f7898;
        font-weight: bold;
        text-decoration: none;
        border-radius: 999px;
        padding: 12px 22px;
        box-shadow: 0 10px 20px rgba(184, 227, 255, 0.22);
        transition: all 0.25s ease;
      }

      .back-btn:hover {
        text-decoration: none;
        color: #476885;
        transform: translateY(-2px);
      }

      .cute-note {
        margin-top: 14px;
        padding: 12px 16px;
        border-radius: 18px;
        background: #fff6fa;
        color: #a06e82;
        border-left: 4px solid #ffbfd0;
        font-size: 14px;
      }

      @media (max-width: 768px) {
        .form-body {
          padding: 24px 18px;
        }

        .back-btn {
          display: inline-block;
          margin-left: 0;
          margin-top: 10px;
        }
      }

      .upload-box {
        background: linear-gradient(135deg, #fff1f7, #eef8ff);
        border: 1px dashed #f3bfd0;
        border-radius: 20px;
        padding: 14px;
      }

      .cute-input {
        border-radius: 999px 0 0 999px !important;
        border: 1px solid #f5cfdb;
        background: #fffafd;
        padding: 12px 16px;
        box-shadow: inset 0 2px 6px rgba(255, 222, 232, 0.14);
      }

      .cute-file-btn {
        background: linear-gradient(135deg, #ffb6c9, #b8e3ff);
        color: #fff;
        font-weight: bold;
        padding: 12px 20px;
        border-radius: 0 999px 999px 0;
        cursor: pointer;
        border: none;
        min-width: 120px;
        text-align: center;
        box-shadow: 0 8px 16px rgba(255, 182, 193, 0.18);
        transition: all 0.25s ease;
      }

      .cute-file-btn:hover {
        transform: translateY(-1px);
        opacity: 0.95;
      }
    </style>
    <script>
      const imageUpload = document.getElementById("imageUpload");
      const fileName = document.getElementById("file-name");

      if (imageUpload) {
        imageUpload.addEventListener("change", function () {
          if (this.files.length > 0) {
            fileName.value = this.files[0].name;
          } else {
            fileName.value = "";
          }
        });
      }
    </script>
  </head>

  <body>
    <%- include('navbar.ejs') %>

    <div class="container form-page">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="form-card">
            <div class="form-header">
              <h2>🍰 เพิ่มสินค้าใหม่</h2>
              <p>เติมเมนูน่ารัก ๆ ให้ร้านคาเฟ่ของเรา</p>
            </div>

            <div class="form-body">
              <form
                method="POST"
                action="/insert"
                enctype="multipart/form-data"
              >
                <div class="form-group">
                  <label>ชื่อสินค้า</label>
                  <input
                    type="text"
                    class="form-control"
                    name="name"
                    placeholder="เช่น Strawberry Milk Cake"
                  />
                </div>

                <div class="form-group">
                  <label>ราคา</label>
                  <input
                    type="text"
                    class="form-control"
                    name="price"
                    placeholder="เช่น 129"
                  />
                </div>

                <div class="form-group">
                  <label>ภาพสินค้า</label>

                  <div class="upload-box">
                    <div class="input-group">
                      <input
                        type="text"
                        id="file-name"
                        class="form-control cute-input"
                        placeholder="ยังไม่ได้เลือกไฟล์"
                        readonly
                      />
                      <div class="input-group-append">
                        <label for="imageUpload" class="cute-file-btn mb-0"
                          >เลือกไฟล์</label
                        >
                      </div>
                    </div>
                    <div class="form-group mt-3">
                      <label>หรือวาง URL รูปภาพ</label>
                      <input
                        type="text"
                        class="form-control"
                        name="imageUrl"
                        placeholder="https://example.com/image.jpg"
                      />
                    </div>

                    <input
                      type="file"
                      id="imageUpload"
                      class="d-none"
                      name="image"
                      accept="image/*"
                    />

                    <small class="form-text text-muted mt-2">
                      อัปโหลดรูปสินค้าแบบน่ารัก ๆ ได้เลย
                    </small>
                  </div>
                </div>

                <div class="form-group">
                  <label>รายละเอียด</label>
                  <textarea
                    class="form-control"
                    cols="30"
                    rows="5"
                    name="description"
                    placeholder="อธิบายความน่ากินของเมนูนี้แบบละมุน ๆ"
                  ></textarea>
                </div>

                <div class="cute-note">
                  ✨ เคล็ดลับ: ใส่ชื่อเมนูให้น่ารัก รูปชัด ๆ
                  และคำอธิบายสั้นแต่ชวนกิน จะทำให้ร้านดูนุ่มนิ่มขึ้นอีกเยอะ
                </div>

                <div class="mt-4">
                  <button type="submit" class="submit-btn">
                    💾 บันทึกสินค้า
                  </button>
                  <a href="/manage" class="back-btn">ย้อนกลับ</a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
